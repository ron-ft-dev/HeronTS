{
  "name": "heron-ts",
  "version": "0.2.0",
  "description": "My own mini ts library",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "tsup": "^8.0.0"
  }
}
